<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TUUCH QUALITY · Monitoreo del Agua</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="static/style.css">
</head>
<body>

<!-- ═══════════════ HEADER ═══════════════ -->
<header>
  <div class="logo">
    <!-- TUUCH QUALITY LOGO SVG -->
    <div class="logo-icon">
      <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg" width="52" height="63">
        <!-- Circuit/sensor bar top -->
        <rect x="20" y="4" width="60" height="12" rx="3" fill="none" stroke="#40a9ff" stroke-width="2.5"/>
        <rect x="28" y="7" width="10" height="6" rx="1.5" fill="#40a9ff" opacity="0.8"/>
        <rect x="42" y="7" width="10" height="6" rx="1.5" fill="#40a9ff" opacity="0.8"/>
        <rect x="56" y="7" width="10" height="6" rx="1.5" fill="#40a9ff" opacity="0.8"/>
        <line x1="50" y1="16" x2="50" y2="22" stroke="#40a9ff" stroke-width="2"/>
        <!-- Eye outer shape -->
        <path d="M10 48 Q50 15 90 48 Q50 80 10 48 Z" fill="none" stroke="#40a9ff" stroke-width="2.5" stroke-linejoin="round"/>
        <!-- Eye inner rings -->
        <circle cx="50" cy="48" r="14" fill="none" stroke="#69c0ff" stroke-width="2"/>
        <circle cx="50" cy="48" r="8" fill="#40a9ff" opacity="0.9"/>
        <circle cx="50" cy="48" r="4" fill="#021929"/>
        <!-- Specular highlight -->
        <circle cx="54" cy="44" r="2" fill="#bae7ff" opacity="0.7"/>
        <!-- Water waves at bottom of eye -->
        <path d="M18 62 Q30 56 42 62 Q54 68 66 62 Q78 56 82 62" fill="none" stroke="#40a9ff" stroke-width="2" stroke-linecap="round"/>
        <path d="M24 72 Q36 66 48 72 Q60 78 72 72" fill="none" stroke="#69c0ff" stroke-width="1.8" stroke-linecap="round" opacity="0.7"/>
        <!-- Bottom water fill -->
        <path d="M20 68 Q35 60 50 68 Q65 76 80 68 L85 85 Q50 95 15 85 Z" fill="#40a9ff" opacity="0.15"/>
        <path d="M20 68 Q35 60 50 68 Q65 76 80 68" fill="none" stroke="#40a9ff" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="logo-text">
      <h1>TUUCH QUALITY</h1>
      <p>MONITOREO DEL AGUA</p>
    </div>
  </div>

  <div class="header-title">DASHBOARD PRINCIPAL</div>

  <div class="header-right">

    <!-- ── BOTÓN START / STOP ── -->
    <button id="btnStartStop"
            class="ss-btn ss-running"
            onclick="toggleStartStop()"
            title="Iniciar / Detener flujo de datos">
      <span class="ss-dot ss-dot-run"></span>
      <span class="ss-label">STOP</span>
    </button>

    <div class="status-badge">
      <span class="status-dot"></span>
      ESP32 Conectado
    </div>
    <div class="battery">
      📶
      <div class="batt-bars">
        <span style="height:8px"></span>
        <span style="height:11px"></span>
        <span style="height:14px"></span>
        <span style="height:17px"></span>
      </div>
      85%
    </div>
  </div>
</header>

<!-- ═══════════════ FROZEN OVERLAY ═══════════════ -->
<div id="frozenOverlay">
  <div class="frozen-card">
    <div class="frozen-icon">⏸</div>
    <h2>MONITOREO PAUSADO</h2>
    <p>El flujo de datos del ESP32 está detenido.<br>Presiona <strong>START</strong> para reanudar.</p>
    <button class="frozen-resume" onclick="toggleStartStop()">▶ REANUDAR</button>
  </div>
</div>

<!-- ═══════════════ MAIN GRID ═══════════════ -->
<div class="main">

  <!-- ── LEFT: PARAMETER CARDS ── -->
  <div class="params-col" id="paramsCol">

    <div class="param-card ph" id="card-ph">
      <div class="param-icon" style="background:rgba(64,169,255,.12);border:1px solid rgba(64,169,255,.3)">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
          <path d="M12 2C8.5 2 5 6.2 5 10.5C5 16.5 12 22 12 22C12 22 19 16.5 19 10.5C19 6.2 15.5 2 12 2Z" stroke="#40a9ff" stroke-width="1.6" fill="rgba(64,169,255,0.15)"/>
          <circle cx="12" cy="10.5" r="2.5" fill="#40a9ff"/>
        </svg>
      </div>
      <div class="param-center">
        <h3>pH</h3>
        <p>Potencial de Hidrógeno</p>
        <div class="param-value">
          <span class="val" id="val-ph" style="color:var(--ph)">--</span>
          <span class="param-badge badge-warn" id="badge-ph">SIN DATOS</span>
        </div>
      </div>
      <canvas class="mini-spark" id="spark-ph"></canvas>
    </div>

    <div class="param-card temp" id="card-temperatura">
      <div class="param-icon" style="background:rgba(54,207,201,.12);border:1px solid rgba(54,207,201,.3)">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
          <rect x="10" y="3" width="4" height="12" rx="2" stroke="#36cfc9" stroke-width="1.6" fill="rgba(54,207,201,0.15)"/>
          <circle cx="12" cy="17.5" r="3.5" stroke="#36cfc9" stroke-width="1.6" fill="rgba(54,207,201,0.25)"/>
          <line x1="14" y1="7"  x2="16" y2="7"  stroke="#36cfc9" stroke-width="1.4"/>
          <line x1="14" y1="10" x2="16" y2="10" stroke="#36cfc9" stroke-width="1.4"/>
        </svg>
      </div>
      <div class="param-center">
        <h3>Temperatura</h3>
        <p>Temperatura del agua</p>
        <div class="param-value">
          <span class="val" id="val-temperatura" style="color:var(--temp)">--</span>
          <span class="unit">°C</span>
          <span class="param-badge badge-warn" id="badge-temperatura">SIN DATOS</span>
        </div>
      </div>
      <canvas class="mini-spark" id="spark-temperatura"></canvas>
    </div>

    <div class="param-card orp" id="card-orp">
      <div class="param-icon" style="background:rgba(146,84,222,.12);border:1px solid rgba(146,84,222,.3)">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
          <polygon points="12,2 3,14 12,14 12,22 21,10 12,10" stroke="#9254de" stroke-width="1.6" stroke-linejoin="round" fill="rgba(146,84,222,0.2)"/>
        </svg>
      </div>
      <div class="param-center">
        <h3>ORP</h3>
        <p>Potencial de Oxidación</p>
        <div class="param-value">
          <span class="val" id="val-orp" style="color:var(--orp)">--</span>
          <span class="unit">mV</span>
          <span class="param-badge badge-warn" id="badge-orp">SIN DATOS</span>
        </div>
      </div>
      <canvas class="mini-spark" id="spark-orp"></canvas>
    </div>

    <div class="param-card cond" id="card-conductividad">
      <div class="param-icon" style="background:rgba(24,144,255,.12);border:1px solid rgba(24,144,255,.3)">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
          <polyline points="2,12 5,6 8,17 11,7 14,15 17,4 20,12 22,12" stroke="#1890ff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="param-center">
        <h3>Conductividad</h3>
        <p>Conductividad eléctrica</p>
        <div class="param-value">
          <span class="val" id="val-conductividad" style="color:var(--cond)">--</span>
          <span class="unit">µS/cm</span>
          <span class="param-badge badge-warn" id="badge-conductividad">SIN DATOS</span>
        </div>
      </div>
      <canvas class="mini-spark" id="spark-conductividad"></canvas>
    </div>

    <div class="param-card turb" id="card-turbidez">
      <div class="param-icon" style="background:rgba(255,169,64,.12);border:1px solid rgba(255,169,64,.3)">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
          <circle cx="12" cy="12" r="4.5" stroke="#ffa940" stroke-width="1.6" fill="rgba(255,169,64,0.15)"/>
          <line x1="12" y1="2"  x2="12" y2="5"  stroke="#ffa940" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="12" y1="19" x2="12" y2="22" stroke="#ffa940" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="2"  y1="12" x2="5"  y2="12" stroke="#ffa940" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="19" y1="12" x2="22" y2="12" stroke="#ffa940" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="param-center">
        <h3>Turbidez</h3>
        <p>Turbidez del agua</p>
        <div class="param-value">
          <span class="val" id="val-turbidez" style="color:var(--turb)">--</span>
          <span class="unit">NTU</span>
          <span class="param-badge badge-warn" id="badge-turbidez">SIN DATOS</span>
        </div>
      </div>
      <canvas class="mini-spark" id="spark-turbidez"></canvas>
    </div>

    <div class="param-card oxy" id="card-oxigeno">
      <div class="param-icon" style="background:rgba(19,194,194,.12);border:1px solid rgba(19,194,194,.3)">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
          <circle cx="12" cy="12" r="3" fill="rgba(19,194,194,0.25)" stroke="#13c2c2" stroke-width="1.6"/>
          <circle cx="12" cy="12" r="7" stroke="#13c2c2" stroke-width="1.2" stroke-dasharray="2.5 2"/>
          <line x1="5.5"  y1="5.5"  x2="8"    y2="8"    stroke="#13c2c2" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="16"   y1="16"   x2="18.5" y2="18.5" stroke="#13c2c2" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="18.5" y1="5.5"  x2="16"   y2="8"    stroke="#13c2c2" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="8"    y1="16"   x2="5.5"  y2="18.5" stroke="#13c2c2" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="param-center">
        <h3>Oxígeno Disuelto</h3>
        <p>Oxígeno disuelto</p>
        <div class="param-value">
          <span class="val" id="val-oxigeno" style="color:var(--oxy)">--</span>
          <span class="unit">mg/L</span>
          <span class="param-badge badge-warn" id="badge-oxigeno">SIN DATOS</span>
        </div>
      </div>
      <canvas class="mini-spark" id="spark-oxigeno"></canvas>
    </div>

  </div><!-- /params-col -->

  <!-- ── CENTER ── -->
  <div class="center-col">

    <div class="chart-panel">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div class="panel-title">GRÁFICO EN TIEMPO REAL</div>
        <select class="time-select" id="timeRange" onchange="changeTimeRange(this.value)">
          <option value="1H">1H</option>
          <option value="6H">6H</option>
          <option value="24H">24H</option>
        </select>
      </div>
      <div class="chart-wrap">
        <canvas id="mainChart"></canvas>
      </div>
      <div class="legend" id="legend"></div>
    </div>

    <div class="bottom-row">
      <div class="status-panel">
        <!-- TUUCH Logo as status icon -->
        <div class="status-eye">
          <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" width="56" height="56">
            <rect x="22" y="5" width="56" height="11" rx="3" fill="none" stroke="#40a9ff" stroke-width="2.5"/>
            <rect x="30" y="8" width="9" height="5" rx="1.5" fill="#40a9ff" opacity="0.8"/>
            <rect x="43" y="8" width="9" height="5" rx="1.5" fill="#40a9ff" opacity="0.8"/>
            <rect x="56" y="8" width="9" height="5" rx="1.5" fill="#40a9ff" opacity="0.8"/>
            <line x1="50" y1="16" x2="50" y2="21" stroke="#40a9ff" stroke-width="2"/>
            <path d="M10 47 Q50 18 90 47 Q50 76 10 47 Z" fill="none" stroke="#40a9ff" stroke-width="2.5"/>
            <circle cx="50" cy="47" r="13" fill="none" stroke="#69c0ff" stroke-width="2"/>
            <circle cx="50" cy="47" r="7" fill="#40a9ff" opacity="0.9"/>
            <circle cx="50" cy="47" r="3.5" fill="#021929"/>
            <circle cx="54" cy="43" r="1.8" fill="#bae7ff" opacity="0.7"/>
            <path d="M18 60 Q32 54 46 60 Q60 66 74 60 Q82 56 84 60" fill="none" stroke="#40a9ff" stroke-width="1.8" stroke-linecap="round"/>
            <path d="M25 70 Q40 64 55 70 Q70 76 76 70" fill="none" stroke="#69c0ff" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
          </svg>
        </div>
        <div class="status-text">
          <h2>ESTADO GENERAL</h2>
          <div class="quality" id="qualityLabel">SIN DATOS</div>
          <p>Todos los parámetros<br>en rango óptimo</p>
        </div>
      </div>

      <div class="device-panel">
        <div class="panel-title">INFORMACIÓN DEL DISPOSITIVO</div>
        <div class="device-row"><span class="label">Dispositivo</span><span class="value">TUUCH CORE</span></div>
        <div class="device-row"><span class="label">Conexión</span><span class="value" style="color:var(--green)">●●●●</span></div>
        <div class="device-row"><span class="label">Última actualización</span><span class="value" id="lastUpdate">--:--:--</span></div>
        <div class="device-row"><span class="label">Frecuencia de muestreo</span><span class="value">3 segundos</span></div>
        <div class="device-row"><span class="label">Versión de firmware</span><span class="value">v1.2.3</span></div>
      </div>
    </div>

  </div><!-- /center-col -->

  <!-- ── RIGHT ── -->
  <div class="right-col">

    <button class="nav-btn active" onclick="openModal('historial')">
      <div class="nav-icon">📋</div>
      <div class="nav-text"><h4>Historial</h4><p>Consulta registros anteriores</p></div>
      <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
    </button>

    <button class="nav-btn" onclick="openModal('alertas')">
      <div class="nav-icon">🔔</div>
      <div class="nav-text"><h4>Alertas</h4><p>Notificaciones y eventos</p></div>
      <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
    </button>

    <button class="nav-btn" onclick="openModal('reportes')">
      <div class="nav-icon">📊</div>
      <div class="nav-text"><h4>Reportes</h4><p>Genera y exporta reportes</p></div>
      <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
    </button>

    <button class="nav-btn" onclick="openModal('calibracion')">
      <div class="nav-icon">🎯</div>
      <div class="nav-text"><h4>Calibración</h4><p>Configura y calibra sensores</p></div>
      <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
    </button>

    <button class="nav-btn" onclick="openModal('configuracion')">
      <div class="nav-icon">⚙️</div>
      <div class="nav-text"><h4>Configuración</h4><p>Ajustes del sistema</p></div>
      <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
    </button>

    <div class="alerts-panel">
      <div class="alerts-title">
        <span>ÚLTIMAS ALERTAS</span>
        <a href="#" onclick="openModal('alertas');return false">Ver todas</a>
      </div>
      <div id="sideAlerts"></div>
    </div>

  </div><!-- /right-col -->

</div><!-- /main -->


<!-- ═══════════════ MODALS ═══════════════ -->

<div class="overlay" id="modal-historial">
  <div class="modal">
    <div class="modal-header">
      <h2>📋 HISTORIAL DE MEDICIONES</h2>
      <button class="close-btn" onclick="closeModal('historial')">×</button>
    </div>
    <div class="modal-body">
      <div class="hist-stats">
        <div class="hist-stat"><div class="n" id="hist-total">0</div><div class="l">Total pruebas</div></div>
        <div class="hist-stat"><div class="n" id="hist-hoy">0</div><div class="l">Hoy</div></div>
        <div class="hist-stat"><div class="n" id="hist-alertas">0</div><div class="l">Alertas hoy</div></div>
      </div>
      <table class="hist-table">
        <thead><tr>
          <th>#</th><th>HORA</th><th>pH</th><th>TEMP °C</th>
          <th>ORP mV</th><th>COND µS</th><th>TURB NTU</th><th>O₂ mg/L</th>
        </tr></thead>
        <tbody id="histBody"></tbody>
      </table>
    </div>
  </div>
</div>

<div class="overlay" id="modal-alertas">
  <div class="modal">
    <div class="modal-header">
      <h2>🔔 PANEL DE ALERTAS</h2>
      <button class="close-btn" onclick="closeModal('alertas')">×</button>
    </div>
    <div class="modal-body" id="alertBody"></div>
  </div>
</div>

<div class="overlay" id="modal-reportes">
  <div class="modal">
    <div class="modal-header">
      <h2>📊 GENERAR REPORTE</h2>
      <button class="close-btn" onclick="closeModal('reportes')">×</button>
    </div>
    <div class="modal-body">
      <div class="report-form">
        <div class="form-group">
          <label>SELECCIONAR FECHA</label>
          <input type="date" id="reportDate">
        </div>
        <div class="form-group">
          <label>FORMATO</label>
          <select id="reportFormat">
            <option value="csv">CSV (Excel compatible)</option>
            <option value="txt">TXT (texto plano)</option>
          </select>
        </div>
        <button class="btn-primary" onclick="downloadReport()">⬇ DESCARGAR REPORTE</button>
      </div>
      <div id="reportMsg" style="margin-top:14px;font-size:12px;color:var(--dim)"></div>
    </div>
  </div>
</div>

<div class="overlay" id="modal-calibracion">
  <div class="modal">
    <div class="modal-header">
      <h2>🎯 CALIBRACIÓN DE SENSORES</h2>
      <button class="close-btn" onclick="closeModal('calibracion')">×</button>
    </div>
    <div class="modal-body">
      <div class="calib-hero">
        <div class="icon">🔧</div>
        <h3>CALIBRACIÓN TÉCNICA REQUERIDA</h3>
        <p>La calibración de sensores es un proceso delicado que requiere equipo especializado y conocimientos técnicos. Para garantizar mediciones precisas, contacta a un técnico certificado.</p>
      </div>
      <div class="contact-card">
        <div class="ci">📞</div>
        <div>
          <h4>Soporte Técnico TUUCH</h4>
          <p>Lunes a Viernes · 8:00 – 18:00 hrs</p>
          <a href="mailto:soporte@tuuchquality.com">soporte@tuuchquality.com</a><br>
          <a href="tel:+529612000000">+52 961 200 0000</a>
        </div>
      </div>
      <div class="contact-card" style="margin-top:10px">
        <div class="ci">⚠️</div>
        <div>
          <h4>No intentes calibrar por tu cuenta</h4>
          <p>Una calibración incorrecta puede generar lecturas erróneas y comprometer la calidad del monitoreo.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="overlay" id="modal-configuracion">
  <div class="modal">
    <div class="modal-header">
      <h2>⚙️ CONFIGURACIÓN</h2>
      <button class="close-btn" onclick="closeModal('configuracion')">×</button>
    </div>
    <div class="modal-body">
      <div class="settings-group">
        <h3>VISIBILIDAD DE PARÁMETROS</h3>
        <div id="settingsToggles"></div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════ GHOST BUTTON + PANEL OCULTO ═══════════════ -->

<!-- Botón fantasma: 60×60px, esquina inferior derecha, completamente invisible -->
<div id="ghostBtn" aria-hidden="true"></div>

<!-- Panel oculto de control (solo visible tras 3 toques rápidos) -->
<div id="devPanel">
  <div id="devPanelInner">
    <div id="devPanelHeader">
      <span id="devPanelTitle">⚙ PANEL DE CONTROL</span>
      <button id="devPanelClose" onclick="closeDevPanel()">✕</button>
    </div>
    <div id="devPanelBody">

      <!-- SLIDERS DE VALORES -->
      <div class="dev-section">
        <div class="dev-section-title">VALORES DE SENSORES</div>

        <div class="dev-row">
          <label class="dev-label">pH</label>
          <input type="range" class="dev-slider" id="dev-ph"
                 min="0" max="14" step="0.01" value="7"
                 oninput="devSetValue('ph', this.value)">
          <span class="dev-val" id="dev-ph-val">7.00</span>
        </div>

        <div class="dev-row">
          <label class="dev-label">Temperatura (°C)</label>
          <input type="range" class="dev-slider" id="dev-temperatura"
                 min="0" max="50" step="0.1" value="22"
                 oninput="devSetValue('temperatura', this.value)">
          <span class="dev-val" id="dev-temperatura-val">22.0</span>
        </div>

        <div class="dev-row">
          <label class="dev-label">ORP (mV)</label>
          <input type="range" class="dev-slider" id="dev-orp"
                 min="-100" max="700" step="1" value="250"
                 oninput="devSetValue('orp', this.value)">
          <span class="dev-val" id="dev-orp-val">250</span>
        </div>

        <div class="dev-row">
          <label class="dev-label">Conductividad (µS/cm)</label>
          <input type="range" class="dev-slider" id="dev-conductividad"
                 min="0" max="1500" step="1" value="500"
                 oninput="devSetValue('conductividad', this.value)">
          <span class="dev-val" id="dev-conductividad-val">500</span>
        </div>

        <div class="dev-row">
          <label class="dev-label">Turbidez (NTU)</label>
          <input type="range" class="dev-slider" id="dev-turbidez"
                 min="0" max="20" step="0.01" value="1"
                 oninput="devSetValue('turbidez', this.value)">
          <span class="dev-val" id="dev-turbidez-val">1.00</span>
        </div>

        <div class="dev-row">
          <label class="dev-label">Oxígeno Disuelto (mg/L)</label>
          <input type="range" class="dev-slider" id="dev-oxigeno"
                 min="0" max="20" step="0.01" value="8"
                 oninput="devSetValue('oxigeno', this.value)">
          <span class="dev-val" id="dev-oxigeno-val">8.00</span>
        </div>
      </div>

      <!-- BOTONES DE ESCENARIO ESTÁTICOS -->
      <div class="dev-section">
        <div class="dev-section-title">PRESETS ESTÁTICOS</div>
        <div class="dev-btn-grid">
          <button class="dev-preset-btn dev-preset-ok"    onclick="devPreset('optimo')">✅ Óptimo</button>
          <button class="dev-preset-btn dev-preset-warn"  onclick="devPreset('precaucion')">⚠️ Precaución</button>
          <button class="dev-preset-btn dev-preset-err"   onclick="devPreset('alerta')">🔴 Alerta</button>
          <button class="dev-preset-btn dev-preset-null"  onclick="devPreset('sinDatos')">📭 Sin datos</button>
          <button class="dev-preset-btn dev-preset-rand"  onclick="devPreset('random')">🎲 Aleatorio</button>
          <button class="dev-preset-btn dev-preset-lock"  onclick="devToggleLock()">🔒 <span id="devLockLabel">Bloquear API</span></button>
        </div>
      </div>

      <!-- SIMULADOR AQUAMONITOR -->
      <div class="dev-section" id="devSimSection">
        <div class="dev-section-title">SIMULADOR AQUAMONITOR</div>

        <!-- Fila de estado + botón conectar -->
        <div class="dev-sim-status-row">
          <div class="dev-sim-dot" id="devSimDot"></div>
          <span class="dev-sim-status-txt" id="devSimStatusText">Desconectado · puerto 5050</span>
          <button class="dev-sim-toggle" id="devSimToggleBtn" onclick="devToggleSim()">Conectar</button>
        </div>

        <!-- Info del escenario activo (oculto hasta conectar) -->
        <div id="devSimInfo" style="display:none; margin-bottom:8px;">
          <div class="dev-sim-scenario-name" id="devSimScenario">—</div>
          <div class="dev-sim-scenario-desc" id="devSimDesc">—</div>
          <!-- Barra de animación -->
          <div class="dev-sim-anim">
            <div class="dev-sim-anim-bar" id="devSimAnimBar"></div>
          </div>
        </div>

        <!-- Botones de escenario -->
        <div class="dev-btn-grid" style="margin-top:8px">
          <button class="dev-preset-btn dev-preset-ok"   onclick="cambiarEscenario('limpia')">💧 Limpia</button>
          <button class="dev-preset-btn dev-preset-warn" onclick="cambiarEscenario('contaminada')">☠️ Contaminada</button>
          <button class="dev-preset-btn dev-preset-err"  onclick="cambiarEscenario('eutro')">🌿 Eutro</button>
          <button class="dev-preset-btn dev-preset-ok"   onclick="cambiarEscenario('tratada')">✨ Tratada</button>
          <button class="dev-preset-btn dev-preset-null" onclick="cambiarEscenario('lluvia')">🌧️ Lluvia</button>
          <button class="dev-preset-btn dev-preset-err"  onclick="cambiarEscenario('industrial')">🏭 Industrial</button>
        </div>
      </div>

      <!-- ESTADO -->
      <div class="dev-section">
        <div class="dev-section-title">ESTADO DEL PANEL</div>
        <div class="dev-status-row">
          <span class="dev-dim">Modo:</span>
          <span id="devModeLabel" style="color:#36cfc9">AUTOMÁTICO</span>
        </div>
        <div class="dev-status-row">
          <span class="dev-dim">API bloqueada:</span>
          <span id="devApiLabel" style="color:#36cfc9">NO</span>
        </div>
        <button class="dev-reset-btn" onclick="devReset()">↺ Restaurar modo automático</button>
      </div>

    </div>
  </div>
</div>

<script src="static/app.js"></script>
</body>
</html>
